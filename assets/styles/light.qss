QLabel#SignalMark,
QLabel#HeroArt {
    background: rgba(255, 255, 255, 238);
    border: 1px solid rgba(73, 93, 124, 38);
    border-radius: 16px;
}

QLabel#AppLogo,
QLabel#SettingsHeaderIcon {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #11376b,
        stop:0.55 #1f68ec,
        stop:1 #0e9f8f);
    border: 1px solid rgba(255, 255, 255, 148);
    border-radius: 24px;
}

QLabel#AppTitle,
QLabel#SettingsWindowTitle,
QLabel#DashboardTitle,
QLabel#SidebarBrandName {
    color: #152033;
    font-weight: 900;
    letter-spacing: -0.3px;
}

QLabel#AppTitle,
QLabel#SettingsWindowTitle {
    font-size: 30px;
}

QLabel#DashboardTitle {
    font-size: 28px;
}

QLabel#SidebarBrandName {
