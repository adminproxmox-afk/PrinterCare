QFrame#RailMetaCard {
    border-left: 5px solid #e0a11a;
}

QFrame#HeroArtFrame,
QFrame#OverviewBanner,
QFrame#SettingsOverviewBanner {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffffff,
        stop:0.52 #f3f7fb,
        stop:1 #ebf2fa);
    border: 1px solid rgba(73, 93, 124, 54);
    border-radius: 24px;
}

QFrame#OverviewBanner,
QFrame#SettingsOverviewBanner {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #143057,
        stop:0.55 #1f68ec,
        stop:1 #0e9f8f);
}

QLabel#HeroArt {
    background: transparent;
    border: none;
    padding: 8px;
}

QLabel#AppLogo,
QLabel#SettingsHeaderIcon,
QLabel#SummaryIcon,
QLabel#MetricIcon,
QLabel#BannerIcon,
