/* Redesign override layer */
QWidget#MainWindowRoot,
QWidget#SettingsWindowRoot {
    background: qradialgradient(cx:0.18, cy:0.10, radius:1.18, fx:0.18, fy:0.10,
        stop:0 #ffffff,
        stop:0.42 #f6f9fd,
        stop:1 #dfe8f3);
    color: #162033;
    font-family: "Segoe UI Variable Text", "Segoe UI", sans-serif;
}

QFrame#ShellCard,
QFrame#SettingsPagesCard {
    background: rgba(255, 255, 255, 240);
    border: 1px solid rgba(73, 93, 124, 36);
    border-radius: 28px;
}

QFrame#ShellCard {
    border-top: 4px solid #1f68ec;
}

QFrame#SidebarPanel,
QFrame#SummaryCard,
QFrame#CompanionCard,
QFrame#SignalsCard,
