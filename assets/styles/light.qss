QWidget#MainWindowRoot,
QWidget#SettingsWindowRoot {
    background: qradialgradient(cx:0.20, cy:0.10, radius:1.18, fx:0.20, fy:0.10,
        stop:0 #ffffff,
        stop:0.42 #f4f7fb,
        stop:1 #dfe8f3);
    color: #182235;
    font-family: "Segoe UI Variable Text", "Segoe UI", sans-serif;
}

QDialog#SettingsWindow {
    background: transparent;
}

QStackedWidget#SettingsPages {
    background: transparent;
    border: none;
}

QFrame#ShellCard,
QFrame#SettingsPagesCard {
    background: rgba(255, 255, 255, 236);
    border: 1px solid rgba(73, 93, 124, 38);
    border-radius: 26px;
}

QFrame#ShellCard {
    border-top: 4px solid #1f68ec;
}

QFrame#SidebarPanel,
QFrame#SummaryCard,
QFrame#CompanionCard,
QFrame#SignalsCard,
QFrame#QuickActionsCard,
QFrame#StatusBoardCard,
QFrame#HeroCard,
QFrame#DesignerPromptCard {
    background: rgba(255, 255, 255, 240);
    border: 1px solid rgba(73, 93, 124, 34);
    border-radius: 22px;
}

QFrame#SidebarPanel {
    border-left: 5px solid #1f68ec;
}

QFrame#SummaryCard {
    border-left: 5px solid #1f68ec;
}

QFrame#CompanionCard {
    border-left: 5px solid #1f68ec;
}

QFrame#SignalsCard {
    border-left: 5px solid #4d7fe0;
}

QFrame#QuickActionsCard,
QFrame#StatusBoardCard {
    border-left: 5px solid #0e9f8f;
}

QFrame#HeroCard {
    border-left: 5px solid #1f68ec;
}

QFrame#HeroArtFrame {
    background: qradialgradient(cx:0.45, cy:0.35, radius:1.0,
        fx:0.45, fy:0.35,
        stop:0 rgba(184, 213, 255, 255),
        stop:0.52 rgba(243, 247, 251, 248),
        stop:1 rgba(227, 236, 246, 248));
    border: 1px solid rgba(31, 104, 236, 52);
    border-radius: 22px;
}

QFrame#DesignerPromptCard {
    border-left: 5px solid #1f68ec;
}

QFrame#DashboardRail,
QFrame#SettingsRail {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 rgba(255, 255, 255, 244),
        stop:1 rgba(240, 246, 253, 246));
    border: 1px solid rgba(73, 93, 124, 34);
    border-left: 5px solid #1f68ec;
    border-radius: 24px;
}

QFrame#RailMetaCard,
QFrame#HeroCard,
QFrame#MaintenanceCard,
QFrame#SettingsHeaderCard,
QFrame#SettingsCard,
QFrame#SettingsFooterCard,
QFrame#HistoryPanel,
QFrame#MetricsRail {
    background: rgba(255, 255, 255, 240);
    border: 1px solid rgba(73, 93, 124, 34);
    border-radius: 22px;
}

QFrame#HeroCard {
    border-left: 5px solid #1f68ec;
}

QFrame#MaintenanceCard {
    border-left: 5px solid #0e9f8f;
}

QFrame#SettingsHeaderCard {
    border-left: 5px solid #1f68ec;
}

QFrame#SettingsFooterCard {
    border-left: 5px solid #0e9f8f;
}

QFrame#OverviewBanner,
QFrame#SettingsOverviewBanner {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #143057,
        stop:0.52 #1e67b8,
        stop:1 #118f83);
    border: 1px solid rgba(255, 255, 255, 92);
    border-radius: 24px;
}

QLabel#AppLogo,
QLabel#SettingsHeaderIcon {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #11376b,
        stop:0.55 #1f68ec,
        stop:1 #0e9f8f);
    border: 1px solid rgba(255, 255, 255, 156);
    border-radius: 22px;
    color: #ffffff;
}

QLabel#AppTitle,
QLabel#SettingsWindowTitle {
    color: #121a2a;
    font-size: 30px;
    font-weight: 900;
    letter-spacing: 0.2px;
}

QLabel#SidebarBrandName,
QLabel#DashboardTitle,
QLabel#CardTitle,
QLabel#PromptTitle {
    color: #121a2a;
    font-size: 20px;
    font-weight: 900;
}

QLabel#SidebarBrandName {
    font-size: 19px;
}

QLabel#DashboardTitle {
    font-size: 28px;
}

QLabel#AppSubtitle,
QLabel#SettingsWindowSubtitle,
QLabel#MetricDescription,
QLabel#SettingsSectionDescription,
QLabel#SettingsValueLabel,
QLabel#SettingsDescriptionLabel,
QLabel#SettingsInfoLine,
QLabel#ServiceRowValue,
QLabel#RailSubtitle,
QLabel#RailNote,
QLabel#SidebarBrandText,
QLabel#DashboardSubtitle,
QLabel#CardDescription,
QLabel#SidebarNote,
QLabel#SidebarCopyright,
QLabel#HistoryMetaLine,
QLabel#PromptLead,
QLabel#PromptBulletText {
    color: #5f6d82;
    font-size: 13px;
}

QLabel#HeaderStatusText {
    color: #5f6d82;
    font-size: 13px;
    font-weight: 600;
}

QLabel#HeaderStatusDot {
    background: #24b76a;
    border-radius: 3px;
    min-width: 6px;
    max-width: 6px;
    min-height: 6px;
    max-height: 6px;
}

QLabel#SummaryPrefix {
    color: #121a2a;
    font-size: 18px;
    font-weight: 900;
}

QLabel#SummaryFooterText {
    color: #536174;
    font-size: 13px;
    font-weight: 700;
}

QLabel#ServiceRowHint {
    color: #7b889b;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
}

QLabel#RailNote {
    font-size: 12px;
}

QLabel#StatusChip,
QLabel#SettingsProfileBadge,
QLabel#MiniPill {
    background: rgba(232, 249, 240, 250);
    color: #15824b;
    border: 1px solid rgba(36, 183, 106, 70);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 12px;
    font-weight: 800;
}

QLabel#RailTitle,
QLabel#MetricTitle,
QLabel#SettingsSectionTitle,
QLabel#ServiceRowTitle,
QLabel#HistoryPanelTitle {
    color: #121a2a;
    font-size: 15px;
    font-weight: 900;
}

QLabel#RailTitle {
    font-size: 18px;
}

QLabel#HeroKicker {
    color: #175cc8;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 1.4px;
}

QLabel#PromptSectionTitle {
    color: #175cc8;
    font-size: 15px;
    font-weight: 900;
    margin-top: 4px;
}

QLabel#PromptBullet {
    color: #175cc8;
    font-size: 16px;
    font-weight: 900;
}

QLabel#SettingsBannerKicker,
QLabel#BannerKicker {
    color: #175cc8;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 1.4px;
}

QLabel#BannerKicker,
QLabel#SettingsBannerKicker,
QLabel#BannerTitle,
QLabel#SettingsBannerTitle,
QLabel#BannerSubtitle,
QLabel#SettingsBannerSubtitle {
    color: #ffffff;
}

QLabel#BannerTitle,
QLabel#SettingsBannerTitle {
    font-size: 19px;
    font-weight: 900;
}

QLabel#BannerSubtitle,
QLabel#SettingsBannerSubtitle {
    color: rgba(255, 255, 255, 220);
    font-size: 12px;
}

QLabel#HeroTitle {
    color: #121a2a;
    font-size: 28px;
    font-weight: 900;
}

QLabel#HeroDescription {
    color: #536174;
    font-size: 14px;
}

QLabel#SignalText {
    color: #31415e;
    font-size: 13px;
}

QLabel#PromptTitle {
    font-size: 18px;
    line-height: 1.15;
}

QLabel#PromptLead {
    font-size: 14px;
    line-height: 1.5;
}

QFrame#ServiceStatusRow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffffff,
        stop:1 #f3f7fb);
    border: 1px solid rgba(73, 93, 124, 34);
    border-left: 5px solid #0e9f8f;
    border-radius: 20px;
}

QFrame#MetricCard {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #ffffff,
        stop:1 #f2f6fb);
    border: 1px solid rgba(73, 93, 124, 34);
    border-top: 4px solid #1f68ec;
    border-radius: 18px;
}

QFrame#StatusTile,
QFrame#SignalRow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffffff,
        stop:1 #f2f6fb);
    border: 1px solid rgba(73, 93, 124, 34);
    border-radius: 18px;
}

QFrame#StatusTile {
    border-top: 4px solid #0e9f8f;
}

QLabel#StatusTileIcon,
QLabel#SummaryIcon,
QLabel#SignalMark {
    background: rgba(255, 255, 255, 238);
    border: 1px solid rgba(73, 93, 124, 38);
    border-radius: 14px;
}

QLabel#StatusTileTitle {
    color: #121a2a;
    font-size: 14px;
    font-weight: 900;
}

QLabel#StatusTileValue {
    color: #121a2a;
    font-size: 22px;
    font-weight: 900;
    line-height: 1.2;
}

QLabel#StatusTileCaption,
QLabel#HeroArtCaption {
    color: #175cc8;
    font-size: 12px;
    font-weight: 700;
}

QScrollArea#PromptScroll {
    background: transparent;
    border: none;
}

QFrame#MetricCard:hover,
QFrame#ServiceStatusRow:hover,
QFrame#SettingsCard:hover,
QFrame#MetricsRail:hover,
QFrame#RailMetaCard:hover,
QFrame#DashboardRail:hover,
QFrame#SettingsRail:hover,
QFrame#SidebarPanel:hover,
QFrame#SummaryCard:hover,
QFrame#CompanionCard:hover,
QFrame#SignalsCard:hover,
QFrame#QuickActionsCard:hover,
QFrame#StatusBoardCard:hover,
QFrame#HeroCard:hover,
QFrame#HeroArtFrame:hover,
QFrame#DesignerPromptCard:hover,
QFrame#StatusTile:hover,
QFrame#SignalRow:hover {
    border-color: rgba(31, 104, 236, 90);
    background: rgba(251, 253, 255, 252);
}

QLabel#MetricBadge {
    background: #182235;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 140);
    border-radius: 24px;
    font-size: 14px;
    font-weight: 850;
}

QLabel#MetricIcon,
QLabel#BannerIcon,
QLabel#ServiceRowIcon,
QLabel#HistoryHeaderIcon,
QLabel#SummaryIcon,
QLabel#StatusTileIcon,
QLabel#SignalMark {
    background: rgba(255, 255, 255, 238);
    border: 1px solid rgba(73, 93, 124, 38);
    border-radius: 14px;
}

QWidget#PromptContent {
    background: transparent;
}

QLabel#ServiceRowValue {
    background: rgba(235, 243, 255, 246);
    color: #184fbd;
    border: 1px solid rgba(31, 104, 236, 56);
    border-radius: 16px;
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 750;
}

QLabel#BannerIcon {
    background: rgba(255, 255, 255, 44);
    border-color: rgba(255, 255, 255, 76);
}

QFrame#HistoryPanel {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 rgba(251, 253, 255, 248),
        stop:1 rgba(242, 247, 252, 250));
}

QFrame#SettingsCardAccent {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #1f68ec,
        stop:0.48 #0e9f8f,
        stop:1 #e0a11a);
    border: none;
    border-radius: 2px;
}

QPushButton#PrimaryActionButton,
QPushButton#SecondaryActionButton,
QToolButton#ThemeToggleButton {
    border-radius: 14px;
    padding: 11px 16px;
    font-size: 13px;
    font-weight: 800;
}

QPushButton#PrimaryActionButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #1f68ec,
        stop:1 #125ad0);
    color: #ffffff;
    border: 1px solid #125ad0;
}

QPushButton#PrimaryActionButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #2b75f3,
        stop:1 #1f68ec);
}

QPushButton#PrimaryActionButton:pressed {
    background: #114ea9;
}

QPushButton#SecondaryActionButton,
QToolButton#ThemeToggleButton {
    background: rgba(255, 255, 255, 246);
    color: #182235;
    border: 1px solid rgba(73, 93, 124, 48);
}

QPushButton#SecondaryActionButton:hover,
QToolButton#ThemeToggleButton:hover {
    background: #f4f8fc;
    border-color: rgba(31, 104, 236, 92);
}

QPushButton#SecondaryActionButton:pressed,
QToolButton#ThemeToggleButton:pressed {
    background: #e8eef7;
}

QPushButton#PrimaryActionButton:focus,
QPushButton#SecondaryActionButton:focus,
QToolButton#ThemeToggleButton:focus,
QComboBox#SettingsCombo:focus,
QSpinBox#SettingsSpinBox:focus,
QListWidget#SettingsNavigation:focus,
QListWidget#HistoryList:focus {
    border-color: #1f68ec;
}

QPushButton#PrimaryActionButton:disabled,
QPushButton#SecondaryActionButton:disabled,
QToolButton#ThemeToggleButton:disabled {
    color: #8a96a9;
    background: rgba(255, 255, 255, 182);
    border-color: rgba(73, 93, 124, 22);
}

QCheckBox#SettingsToggle {
    spacing: 10px;
    color: #182235;
    font-weight: 650;
}

QCheckBox#SettingsToggle::indicator {
    width: 18px;
    height: 18px;
    border-radius: 6px;
    border: 1px solid rgba(73, 93, 124, 68);
    background: rgba(255, 255, 255, 248);
}

QCheckBox#SettingsToggle::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #1f68ec,
        stop:1 #0e9f8f);
    border-color: #1f68ec;
}

QComboBox#SettingsCombo,
QSpinBox#SettingsSpinBox {
    background: rgba(255, 255, 255, 246);
    color: #182235;
    border: 1px solid rgba(73, 93, 124, 56);
    border-radius: 14px;
    padding: 10px 14px;
    min-height: 22px;
    selection-background-color: #1f68ec;
}

QComboBox#SettingsCombo:hover,
QSpinBox#SettingsSpinBox:hover {
    border-color: rgba(31, 104, 236, 90);
}

QComboBox#SettingsCombo::drop-down {
    border: none;
    width: 22px;
}

QComboBox#SettingsCombo::down-arrow {
    image: none;
}

QListWidget#SettingsNavigation,
QListWidget#HistoryList {
    background: transparent;
    border: none;
    outline: none;
    selection-background-color: transparent;
}

QListWidget#SettingsNavigation::item {
    background: rgba(244, 248, 253, 220);
    color: #182235;
    border: 1px solid rgba(73, 93, 124, 30);
    border-radius: 16px;
    padding: 12px 14px;
    margin-bottom: 6px;
}

QListWidget#SettingsNavigation::item:hover {
    background: rgba(232, 241, 255, 245);
    border-color: rgba(31, 104, 236, 84);
}

QListWidget#SettingsNavigation::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #1f68ec,
        stop:1 #0e9f8f);
    color: #ffffff;
    border-color: transparent;
    font-weight: 800;
}

QListWidget#SidebarNavigation {
    background: transparent;
    border: none;
    outline: none;
    selection-background-color: transparent;
}

QListWidget#SidebarNavigation::item {
    background: rgba(244, 248, 253, 220);
    color: #182235;
    border: 1px solid rgba(73, 93, 124, 30);
    border-radius: 16px;
    padding: 12px 14px;
    margin-bottom: 6px;
}

QListWidget#SidebarNavigation::item:hover {
    background: rgba(232, 241, 255, 245);
    border-color: rgba(31, 104, 236, 84);
}

QListWidget#SidebarNavigation::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #1f68ec,
        stop:1 #0e9f8f);
    color: #ffffff;
    border-color: transparent;
    font-weight: 800;
}

QListWidget#HistoryList::item {
    background: rgba(255, 255, 255, 236);
    color: #182235;
    border: 1px solid rgba(73, 93, 124, 28);
    border-left: 4px solid #0e9f8f;
    border-radius: 16px;
    padding: 12px 14px;
    min-height: 48px;
}

QListWidget#HistoryList::item:hover {
    border-color: rgba(31, 104, 236, 82);
    background: rgba(245, 249, 255, 248);
}

QScrollArea {
    background: transparent;
    border: none;
}

QScrollBar:vertical {
    background: transparent;
    width: 12px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: rgba(31, 104, 236, 128);
    border-radius: 5px;
    min-height: 28px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(31, 104, 236, 168);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
    border: none;
}

QLabel#FooterLabel {
    color: #6d7a8f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.4px;
}
