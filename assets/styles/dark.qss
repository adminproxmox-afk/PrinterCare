/* Redesign override layer */
QWidget#MainWindowRoot,
QWidget#SettingsWindowRoot {
    background: qradialgradient(cx:0.18, cy:0.10, radius:1.15, fx:0.18, fy:0.10,
        stop:0 #182338,
        stop:0.46 #0b1220,
        stop:1 #05070d);
    color: #eff4fb;
    font-family: "Segoe UI Variable Text", "Segoe UI", sans-serif;
}

QFrame#ShellCard,
QFrame#SettingsPagesCard {
    background: rgba(11, 16, 27, 244);
    border: 1px solid rgba(115, 132, 160, 54);
    border-radius: 28px;
}

QFrame#ShellCard {
    border-top: 4px solid #5c8dff;
}

QFrame#SidebarPanel,
QFrame#SummaryCard,
QFrame#CompanionCard,
QFrame#SignalsCard,
QFrame#QuickActionsCard,
QFrame#StatusBoardCard,
QFrame#HeroCard,
QFrame#DesignerPromptCard,
QFrame#RailMetaCard,
QFrame#MaintenanceCard,
QFrame#SettingsHeaderCard,
QFrame#SettingsCard,
QFrame#SettingsFooterCard,
QFrame#HistoryPanel,
QFrame#MetricsRail,
QFrame#DashboardRail,
QFrame#SettingsRail {
    background: rgba(14, 20, 32, 240);
    border: 1px solid rgba(115, 132, 160, 48);
    border-radius: 24px;
}

QFrame#SidebarPanel,
QFrame#SummaryCard,
QFrame#CompanionCard,
QFrame#HeroCard,
QFrame#SettingsHeaderCard,
QFrame#SettingsCard {
    border-left: 5px solid #5c8dff;
}

QFrame#SignalsCard,
QFrame#StatusBoardCard,
QFrame#SettingsFooterCard,
QFrame#MaintenanceCard {
    border-left: 5px solid #2fd0bb;
}

QFrame#QuickActionsCard,
QFrame#DesignerPromptCard,
QFrame#RailMetaCard {
    border-left: 5px solid #f0b15e;
}

QFrame#HeroArtFrame,
QFrame#OverviewBanner,
QFrame#SettingsOverviewBanner {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 rgba(18, 34, 63, 252),
        stop:0.56 rgba(12, 19, 34, 252),
        stop:1 rgba(13, 24, 31, 252));
    border: 1px solid rgba(120, 147, 188, 76);
    border-radius: 24px;
}

QFrame#OverviewBanner,
QFrame#SettingsOverviewBanner {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #121e31,
        stop:0.55 #17355a,
        stop:1 #0f6c62);
}

QLabel#HeroArt {
    background: transparent;
    border: none;
    padding: 8px;
}

QLabel#AppLogo,
QLabel#SettingsHeaderIcon,
QLabel#SummaryIcon,
QLabel#MetricIcon,
QLabel#BannerIcon,
QLabel#ServiceRowIcon,
QLabel#HistoryHeaderIcon,
QLabel#StatusTileIcon,
QLabel#SignalMark,
QLabel#HeroArt {
    background: rgba(15, 24, 38, 242);
    border: 1px solid rgba(119, 143, 176, 64);
    border-radius: 16px;
}

QLabel#AppLogo,
QLabel#SettingsHeaderIcon {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #123565,
        stop:0.55 #5c8dff,
        stop:1 #2fd0bb);
    border: 1px solid rgba(160, 188, 255, 92);
    border-radius: 24px;
}

QLabel#AppTitle,
QLabel#SettingsWindowTitle,
QLabel#DashboardTitle,
QLabel#SidebarBrandName {
    color: #f3f7fc;
    font-weight: 900;
    letter-spacing: -0.3px;
}

QLabel#AppTitle,
QLabel#SettingsWindowTitle {
    font-size: 30px;
}

QLabel#DashboardTitle {
    font-size: 28px;
}

QLabel#SidebarBrandName {
    font-size: 20px;
}

QLabel#CardTitle,
QLabel#PromptTitle,
QLabel#RailTitle,
QLabel#MetricTitle,
QLabel#SettingsSectionTitle,
QLabel#ServiceRowTitle,
QLabel#HistoryPanelTitle,
QLabel#StatusTileTitle {
    color: #f3f7fc;
    font-size: 16px;
    font-weight: 850;
}

QLabel#CardDescription,
QLabel#AppSubtitle,
QLabel#SettingsWindowSubtitle,
QLabel#MetricDescription,
QLabel#SettingsSectionDescription,
QLabel#SettingsValueLabel,
QLabel#SettingsDescriptionLabel,
QLabel#SettingsInfoLine,
QLabel#ServiceRowValue,
QLabel#RailSubtitle,
QLabel#RailNote,
QLabel#SidebarBrandText,
QLabel#DashboardSubtitle,
QLabel#SidebarNote,
QLabel#SidebarCopyright,
QLabel#HistoryMetaLine,
QLabel#PromptLead,
QLabel#PromptBulletText,
QLabel#HeroDescription,
QLabel#SignalText {
    color: #9caac1;
    font-size: 13px;
    line-height: 1.5;
}

QLabel#HeroTitle {
    color: #f6f9fd;
    font-size: 30px;
    font-weight: 900;
    letter-spacing: -0.45px;
}

QLabel#HeroKicker,
QLabel#BannerKicker,
QLabel#SettingsBannerKicker,
QLabel#PromptSectionTitle,
QLabel#ServiceRowHint {
    color: #86b0ff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 1.4px;
    text-transform: uppercase;
}

QLabel#PromptBullet {
    color: #86b0ff;
    font-size: 16px;
    font-weight: 900;
}

QLabel#StatusChip,
QLabel#SettingsProfileBadge,
QLabel#MiniPill {
    background: rgba(20, 92, 66, 220);
    color: #dcfff0;
    border: 1px solid rgba(47, 208, 187, 88);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 12px;
    font-weight: 800;
}

QLabel#SummaryPrefix,
QLabel#StatusTileValue {
    color: #ffffff;
    font-weight: 900;
    letter-spacing: -0.4px;
}

QLabel#SummaryPrefix {
    font-size: 18px;
}

QLabel#StatusTileValue {
    font-size: 23px;
}

QLabel#SummaryFooterText,
QLabel#StatusTileCaption,
QLabel#HeroArtCaption {
    color: #86b0ff;
    font-size: 12px;
    font-weight: 700;
}

QLabel#ServiceRowValue {
    background: rgba(20, 27, 40, 240);
    color: #b8d3ff;
    border: 1px solid rgba(92, 141, 255, 68);
    border-radius: 16px;
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 750;
}

QFrame#MetricCard,
QFrame#ServiceStatusRow,
QFrame#StatusTile,
QFrame#SignalRow,
QFrame#HistoryPanel {
    background: linear-gradient(180deg, rgba(16, 23, 36, 246), rgba(11, 17, 27, 250));
    border: 1px solid rgba(115, 132, 160, 44);
    border-radius: 20px;
}

QFrame#MetricCard {
    border-top: 4px solid #5c8dff;
}

QFrame#ServiceStatusRow {
    border-left: 5px solid #2fd0bb;
}

QFrame#StatusTile {
    border-top: 4px solid #2fd0bb;
}

QFrame#SignalRow {
    border-left: 4px solid #f0b15e;
}

QFrame#HistoryPanel {
    background: linear-gradient(180deg, rgba(12, 18, 29, 248), rgba(9, 14, 22, 250));
}

QScrollArea#PromptScroll {
    background: transparent;
    border: none;
}

QPushButton#PrimaryActionButton,
QToolButton#ThemeToggleButton {
    border-radius: 14px;
    padding: 11px 16px;
    font-size: 13px;
    font-weight: 800;
}

QPushButton#PrimaryActionButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #5c8dff,
        stop:1 #2fd0bb);
    color: #ffffff;
    border: 1px solid #4e7fe0;
}

QPushButton#SecondaryActionButton,
QToolButton#ThemeToggleButton {
    background: rgba(17, 24, 38, 244);
    color: #eef4fb;
    border: 1px solid rgba(115, 132, 160, 54);
}

QPushButton#PrimaryActionButton:hover,
QPushButton#SecondaryActionButton:hover,
QToolButton#ThemeToggleButton:hover,
QListWidget#SidebarNavigation::item:hover,
QListWidget#SettingsNavigation::item:hover,
QListWidget#HistoryList::item:hover,
QFrame#MetricCard:hover,
QFrame#ServiceStatusRow:hover,
QFrame#SettingsCard:hover,
QFrame#MetricsRail:hover,
QFrame#RailMetaCard:hover,
QFrame#DashboardRail:hover,
QFrame#SettingsRail:hover,
QFrame#SidebarPanel:hover,
QFrame#SummaryCard:hover,
QFrame#CompanionCard:hover,
QFrame#SignalsCard:hover,
QFrame#QuickActionsCard:hover,
QFrame#StatusBoardCard:hover,
QFrame#HeroCard:hover,
QFrame#HeroArtFrame:hover,
QFrame#DesignerPromptCard:hover,
QFrame#StatusTile:hover,
QFrame#SignalRow:hover {
    border-color: rgba(92, 141, 255, 104);
    background: rgba(19, 28, 44, 250);
}

QListWidget#SidebarNavigation::item:selected,
QListWidget#SettingsNavigation::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #5c8dff,
        stop:1 #2fd0bb);
    color: #ffffff;
    border-color: transparent;
    font-weight: 800;
}

QListWidget#SidebarNavigation::item,
QListWidget#SettingsNavigation::item,
QListWidget#HistoryList::item {
    background: rgba(16, 23, 36, 240);
    color: #eef4fb;
    border: 1px solid rgba(115, 132, 160, 34);
    border-radius: 16px;
    padding: 12px 14px;
    margin-bottom: 6px;
}

QListWidget#HistoryList::item {
    border-left: 4px solid #2fd0bb;
}

QComboBox#SettingsCombo,
QSpinBox#SettingsSpinBox {
    background: rgba(15, 22, 35, 246);
    color: #eef4fb;
    border: 1px solid rgba(115, 132, 160, 56);
    border-radius: 14px;
    padding: 10px 14px;
    min-height: 22px;
    selection-background-color: #5c8dff;
}

QCheckBox#SettingsToggle::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #5c8dff,
        stop:1 #2fd0bb);
    border-color: #5c8dff;
}

QScrollBar::handle:vertical {
    background: rgba(92, 141, 255, 128);
}

QScrollBar::handle:vertical:hover {
    background: rgba(92, 141, 255, 168);
}
