QWidget#MainWindowRoot,
QWidget#SettingsWindowRoot {
    background: qradialgradient(cx:0.20, cy:0.10, radius:1.15, fx:0.20, fy:0.10,
        stop:0 #141c2d,
        stop:0.48 #0b1120,
        stop:1 #060910);
    color: #eef4fb;
    font-family: "Segoe UI Variable Text", "Segoe UI", sans-serif;
}

QDialog#SettingsWindow {
    background: transparent;
}

QStackedWidget#SettingsPages {
    background: transparent;
    border: none;
}

QFrame#ShellCard,
QFrame#SettingsPagesCard {
    background: rgba(12, 18, 29, 240);
    border: 1px solid rgba(108, 126, 156, 52);
    border-radius: 26px;
}

QFrame#ShellCard {
    border-top: 4px solid #68a1ff;
}

QFrame#SidebarPanel,
QFrame#SummaryCard,
QFrame#CompanionCard,
QFrame#SignalsCard,
QFrame#QuickActionsCard,
QFrame#StatusBoardCard,
QFrame#HeroCard,
QFrame#DesignerPromptCard {
    background: rgba(15, 22, 35, 244);
    border: 1px solid rgba(108, 126, 156, 46);
    border-radius: 22px;
}

QFrame#SidebarPanel {
    border-left: 5px solid #68a1ff;
}

QFrame#SummaryCard {
    border-left: 5px solid #68a1ff;
}

QFrame#CompanionCard {
    border-left: 5px solid #68a1ff;
}

QFrame#SignalsCard {
    border-left: 5px solid #8eb6ff;
}

QFrame#QuickActionsCard,
QFrame#StatusBoardCard {
    border-left: 5px solid #26c6b0;
}

QFrame#HeroCard {
    border-left: 5px solid #68a1ff;
}

QFrame#HeroArtFrame {
    background: qradialgradient(cx:0.45, cy:0.35, radius:1.0,
        fx:0.45, fy:0.35,
        stop:0 rgba(52, 104, 196, 80),
        stop:0.55 rgba(17, 24, 38, 250),
        stop:1 rgba(11, 17, 27, 252));
    border: 1px solid rgba(104, 161, 255, 60);
    border-radius: 22px;
}

QFrame#DesignerPromptCard {
    border-left: 5px solid #68a1ff;
}

QFrame#DashboardRail,
QFrame#SettingsRail {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 rgba(14, 21, 34, 252),
        stop:1 rgba(10, 15, 24, 248));
    border: 1px solid rgba(108, 126, 156, 48);
    border-left: 5px solid #68a1ff;
    border-radius: 24px;
}

QFrame#RailMetaCard,
QFrame#HeroCard,
QFrame#MaintenanceCard,
QFrame#SettingsHeaderCard,
QFrame#SettingsCard,
QFrame#SettingsFooterCard,
QFrame#HistoryPanel,
QFrame#MetricsRail {
    background: rgba(15, 22, 35, 244);
    border: 1px solid rgba(108, 126, 156, 46);
    border-radius: 22px;
}

QFrame#HeroCard {
    border-left: 5px solid #68a1ff;
}

QFrame#MaintenanceCard {
    border-left: 5px solid #26c6b0;
}

QFrame#SettingsHeaderCard {
    border-left: 5px solid #68a1ff;
}

QFrame#SettingsFooterCard {
    border-left: 5px solid #26c6b0;
}

QFrame#OverviewBanner,
QFrame#SettingsOverviewBanner {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #101a2a,
        stop:0.5 #14335e,
        stop:1 #0d7369);
    border: 1px solid rgba(255, 255, 255, 44);
    border-radius: 24px;
}

QLabel#AppLogo,
QLabel#SettingsHeaderIcon {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #10305a,
        stop:0.55 #68a1ff,
        stop:1 #26c6b0);
    border: 1px solid rgba(164, 191, 255, 78);
    border-radius: 22px;
    color: #ffffff;
}

QLabel#AppTitle,
QLabel#SettingsWindowTitle {
    color: #eef4fb;
    font-size: 30px;
    font-weight: 900;
    letter-spacing: 0.2px;
}

QLabel#SidebarBrandName,
QLabel#DashboardTitle,
QLabel#CardTitle,
QLabel#PromptTitle {
    color: #eef4fb;
    font-size: 20px;
    font-weight: 900;
}

QLabel#SidebarBrandName {
    font-size: 19px;
}

QLabel#DashboardTitle {
    font-size: 28px;
}

QLabel#AppSubtitle,
QLabel#SettingsWindowSubtitle,
QLabel#MetricDescription,
QLabel#SettingsSectionDescription,
QLabel#SettingsValueLabel,
QLabel#SettingsDescriptionLabel,
QLabel#SettingsInfoLine,
QLabel#ServiceRowValue,
QLabel#RailSubtitle,
QLabel#RailNote,
QLabel#SidebarBrandText,
QLabel#DashboardSubtitle,
QLabel#CardDescription,
QLabel#SidebarNote,
QLabel#SidebarCopyright,
QLabel#HistoryMetaLine,
QLabel#PromptLead,
QLabel#PromptBulletText {
    color: #a0afc6;
    font-size: 13px;
}

QLabel#HeaderStatusText {
    color: #a0afc6;
    font-size: 13px;
    font-weight: 600;
}

QLabel#HeaderStatusDot {
    background: #51d06c;
    border-radius: 3px;
    min-width: 6px;
    max-width: 6px;
    min-height: 6px;
    max-height: 6px;
}

QLabel#SummaryPrefix {
    color: #eef4fb;
    font-size: 18px;
    font-weight: 900;
}

QLabel#SummaryFooterText {
    color: #c6d2e5;
    font-size: 13px;
    font-weight: 700;
}

QLabel#ServiceRowHint {
    color: #90a0b8;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
}

QLabel#RailNote {
    font-size: 12px;
}

QLabel#StatusChip,
QLabel#SettingsProfileBadge,
QLabel#MiniPill {
    background: rgba(24, 56, 34, 248);
    color: #79e08f;
    border: 1px solid rgba(81, 208, 108, 88);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 12px;
    font-weight: 800;
}

QLabel#RailTitle,
QLabel#MetricTitle,
QLabel#SettingsSectionTitle,
QLabel#ServiceRowTitle,
QLabel#HistoryPanelTitle {
    color: #eef4fb;
    font-size: 15px;
    font-weight: 900;
}

QLabel#RailTitle {
    font-size: 18px;
}

QLabel#HeroKicker {
    color: #8eb6ff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 1.4px;
}

QLabel#PromptSectionTitle {
    color: #8eb6ff;
    font-size: 15px;
    font-weight: 900;
    margin-top: 4px;
}

QLabel#PromptBullet {
    color: #8eb6ff;
    font-size: 16px;
    font-weight: 900;
}

QLabel#SettingsBannerKicker,
QLabel#BannerKicker {
    color: #8eb6ff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 1.4px;
}

QLabel#BannerTitle,
QLabel#SettingsBannerTitle {
    color: #eef4fb;
    font-size: 19px;
    font-weight: 900;
}

QLabel#BannerSubtitle,
QLabel#SettingsBannerSubtitle {
    color: #b4c2d9;
    font-size: 12px;
}

QLabel#HeroTitle {
    color: #eef4fb;
    font-size: 28px;
    font-weight: 900;
}

QLabel#HeroDescription {
    color: #a0afc6;
    font-size: 14px;
}

QLabel#SignalText {
    color: #d9e4f3;
    font-size: 13px;
}

QLabel#PromptTitle {
    font-size: 18px;
    line-height: 1.15;
}

QLabel#PromptLead {
    font-size: 14px;
    line-height: 1.5;
}

QFrame#ServiceStatusRow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 rgba(16, 23, 36, 246),
        stop:1 rgba(11, 17, 27, 250));
    border: 1px solid rgba(108, 126, 156, 42);
    border-left: 5px solid #26c6b0;
    border-radius: 20px;
}

QFrame#MetricCard {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 rgba(17, 25, 39, 244),
        stop:1 rgba(12, 18, 29, 248));
    border: 1px solid rgba(108, 126, 156, 46);
    border-top: 4px solid #68a1ff;
    border-radius: 18px;
}

QFrame#StatusTile,
QFrame#SignalRow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 rgba(17, 25, 39, 244),
        stop:1 rgba(12, 18, 29, 248));
    border: 1px solid rgba(108, 126, 156, 46);
    border-radius: 18px;
}

QFrame#StatusTile {
    border-top: 4px solid #26c6b0;
}

QLabel#StatusTileIcon,
QLabel#SummaryIcon,
QLabel#SignalMark {
    background: rgba(15, 22, 35, 236);
    border: 1px solid rgba(108, 126, 156, 52);
    border-radius: 14px;
}

QLabel#StatusTileTitle {
    color: #eef4fb;
    font-size: 14px;
    font-weight: 900;
}

QLabel#StatusTileValue {
    color: #ffffff;
    font-size: 22px;
    font-weight: 900;
    line-height: 1.2;
}

QLabel#StatusTileCaption,
QLabel#HeroArtCaption {
    color: #8eb6ff;
    font-size: 12px;
    font-weight: 700;
}

QScrollArea#PromptScroll {
    background: transparent;
    border: none;
}

QFrame#MetricCard:hover,
QFrame#ServiceStatusRow:hover,
QFrame#SettingsCard:hover,
QFrame#MetricsRail:hover,
QFrame#RailMetaCard:hover,
QFrame#DashboardRail:hover,
QFrame#SettingsRail:hover,
QFrame#SidebarPanel:hover,
QFrame#SummaryCard:hover,
QFrame#CompanionCard:hover,
QFrame#SignalsCard:hover,
QFrame#QuickActionsCard:hover,
QFrame#StatusBoardCard:hover,
QFrame#HeroCard:hover,
QFrame#HeroArtFrame:hover,
QFrame#DesignerPromptCard:hover,
QFrame#StatusTile:hover,
QFrame#SignalRow:hover {
    border-color: rgba(104, 161, 255, 98);
    background: rgba(19, 28, 44, 250);
}

QLabel#MetricBadge {
    background: #0f1623;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 120);
    border-radius: 24px;
    font-size: 14px;
    font-weight: 850;
}

QLabel#MetricIcon,
QLabel#BannerIcon,
QLabel#ServiceRowIcon,
QLabel#HistoryHeaderIcon,
QLabel#SummaryIcon,
QLabel#StatusTileIcon,
QLabel#SignalMark {
    background: rgba(15, 22, 35, 236);
    border: 1px solid rgba(108, 126, 156, 52);
    border-radius: 14px;
}

QWidget#PromptContent {
    background: transparent;
}

QLabel#ServiceRowValue {
    background: rgba(20, 29, 46, 246);
    color: #a8c7ff;
    border: 1px solid rgba(104, 161, 255, 72);
    border-radius: 16px;
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 750;
}

QLabel#BannerIcon {
    background: rgba(255, 255, 255, 40);
    border-color: rgba(255, 255, 255, 64);
}

QFrame#HistoryPanel {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 rgba(15, 23, 37, 246),
        stop:1 rgba(11, 16, 27, 250));
}

QFrame#SettingsCardAccent {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #68a1ff,
        stop:0.48 #26c6b0,
        stop:1 #e0a11a);
    border: none;
    border-radius: 2px;
}

QPushButton#PrimaryActionButton,
QPushButton#SecondaryActionButton,
QToolButton#ThemeToggleButton {
    border-radius: 14px;
    padding: 11px 16px;
    font-size: 13px;
    font-weight: 800;
}

QPushButton#PrimaryActionButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #68a1ff,
        stop:1 #4b7fe0);
    color: #ffffff;
    border: 1px solid #4d7be0;
}

QPushButton#PrimaryActionButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #7ab1ff,
        stop:1 #68a1ff);
}

QPushButton#PrimaryActionButton:pressed {
    background: #426fc8;
}

QPushButton#SecondaryActionButton,
QToolButton#ThemeToggleButton {
    background: rgba(18, 26, 41, 244);
    color: #eef4fb;
    border: 1px solid rgba(108, 126, 156, 56);
}

QPushButton#SecondaryActionButton:hover,
QToolButton#ThemeToggleButton:hover {
    background: rgba(25, 35, 52, 246);
    border-color: rgba(104, 161, 255, 106);
}

QPushButton#SecondaryActionButton:pressed,
QToolButton#ThemeToggleButton:pressed {
    background: rgba(17, 25, 38, 248);
}

QPushButton#PrimaryActionButton:focus,
QPushButton#SecondaryActionButton:focus,
QToolButton#ThemeToggleButton:focus,
QComboBox#SettingsCombo:focus,
QSpinBox#SettingsSpinBox:focus,
QListWidget#SettingsNavigation:focus,
QListWidget#HistoryList:focus {
    border-color: #68a1ff;
}

QPushButton#PrimaryActionButton:disabled,
QPushButton#SecondaryActionButton:disabled,
QToolButton#ThemeToggleButton:disabled {
    color: #8a96a9;
    background: rgba(18, 26, 41, 204);
    border-color: rgba(108, 126, 156, 24);
}

QCheckBox#SettingsToggle {
    spacing: 10px;
    color: #eef4fb;
    font-weight: 650;
}

QCheckBox#SettingsToggle::indicator {
    width: 18px;
    height: 18px;
    border-radius: 6px;
    border: 1px solid rgba(108, 126, 156, 68);
    background: rgba(15, 22, 35, 248);
}

QCheckBox#SettingsToggle::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #68a1ff,
        stop:1 #26c6b0);
    border-color: #68a1ff;
}

QComboBox#SettingsCombo,
QSpinBox#SettingsSpinBox {
    background: rgba(15, 22, 35, 246);
    color: #eef4fb;
    border: 1px solid rgba(108, 126, 156, 56);
    border-radius: 14px;
    padding: 10px 14px;
    min-height: 22px;
    selection-background-color: #68a1ff;
}

QComboBox#SettingsCombo:hover,
QSpinBox#SettingsSpinBox:hover {
    border-color: rgba(104, 161, 255, 90);
}

QComboBox#SettingsCombo::drop-down {
    border: none;
    width: 22px;
}

QComboBox#SettingsCombo::down-arrow {
    image: none;
}

QListWidget#SettingsNavigation,
QListWidget#HistoryList {
    background: transparent;
    border: none;
    outline: none;
    selection-background-color: transparent;
}

QListWidget#SettingsNavigation::item {
    background: rgba(16, 23, 36, 240);
    color: #eef4fb;
    border: 1px solid rgba(108, 126, 156, 34);
    border-radius: 16px;
    padding: 12px 14px;
    margin-bottom: 6px;
}

QListWidget#SettingsNavigation::item:hover {
    background: rgba(22, 33, 50, 245);
    border-color: rgba(104, 161, 255, 84);
}

QListWidget#SettingsNavigation::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #68a1ff,
        stop:1 #26c6b0);
    color: #ffffff;
    border-color: transparent;
    font-weight: 800;
}

QListWidget#SidebarNavigation {
    background: transparent;
    border: none;
    outline: none;
    selection-background-color: transparent;
}

QListWidget#SidebarNavigation::item {
    background: rgba(16, 23, 36, 240);
    color: #eef4fb;
    border: 1px solid rgba(108, 126, 156, 34);
    border-radius: 16px;
    padding: 12px 14px;
    margin-bottom: 6px;
}

QListWidget#SidebarNavigation::item:hover {
    background: rgba(22, 33, 50, 245);
    border-color: rgba(104, 161, 255, 84);
}

QListWidget#SidebarNavigation::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #68a1ff,
        stop:1 #26c6b0);
    color: #ffffff;
    border-color: transparent;
    font-weight: 800;
}

QListWidget#HistoryList::item {
    background: rgba(16, 23, 36, 236);
    color: #eef4fb;
    border: 1px solid rgba(108, 126, 156, 28);
    border-left: 4px solid #26c6b0;
    border-radius: 16px;
    padding: 12px 14px;
    min-height: 48px;
}

QListWidget#HistoryList::item:hover {
    border-color: rgba(104, 161, 255, 82);
    background: rgba(21, 31, 48, 244);
}

QScrollArea {
    background: transparent;
    border: none;
}

QScrollBar:vertical {
    background: transparent;
    width: 12px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: rgba(104, 161, 255, 128);
    border-radius: 5px;
    min-height: 28px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(104, 161, 255, 168);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
    border: none;
}

QLabel#FooterLabel {
    color: #7f8ea8;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.4px;
}
